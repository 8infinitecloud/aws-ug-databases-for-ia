# ──────────────────────────────────────────────
# AWS Configuration
# ──────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default

# ──────────────────────────────────────────────
# Amazon Bedrock — Models
# ──────────────────────────────────────────────
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# Titan V2 supports 256, 512, or 1024 dimensions.
# Use 256 in production to reduce storage/compute costs by ~75%.
EMBEDDING_DIMENSIONS=1024

# ──────────────────────────────────────────────
# Aurora PostgreSQL (Vector Store)
# Get these values from CloudFormation outputs
# ──────────────────────────────────────────────
AURORA_HOST=your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
AURORA_PORT=5432
AURORA_DB=compliance_db
AURORA_USER=admin
# Password is fetched from Secrets Manager at runtime — do NOT put it here
AURORA_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:aurora-rag-lab-xxxx

# ──────────────────────────────────────────────
# ElastiCache Redis (Session Memory)
# ──────────────────────────────────────────────
REDIS_HOST=your-cluster.xxxx.cache.amazonaws.com
REDIS_PORT=6379
# Session TTL in seconds (2 hours for lab)
REDIS_SESSION_TTL=7200

# ──────────────────────────────────────────────
# DynamoDB (Persistent User Memory)
# ──────────────────────────────────────────────
DYNAMODB_TABLE=rag_user_memory
DYNAMODB_REGION=us-east-1

# ──────────────────────────────────────────────
# S3 (Document Storage)
# ──────────────────────────────────────────────
S3_BUCKET=rag-lab-documents-your-account-id
S3_PREFIX=compliance-docs/

# ──────────────────────────────────────────────
# RAG Pipeline Parameters
# ──────────────────────────────────────────────
# Number of chunks to retrieve per query
RETRIEVAL_TOP_K=5
# Minimum similarity score to include a chunk (0.0 - 1.0)
RETRIEVAL_MIN_SCORE=0.70
# Chunk size in characters
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Max session messages to include in prompt
MAX_SESSION_MESSAGES=10

# ──────────────────────────────────────────────
# Lab/Demo Settings
# ──────────────────────────────────────────────
# Default user ID for the lab demo
DEMO_USER_ID=demo-user-001
# Enable verbose logging to see full prompts in terminal
VERBOSE_LOGGING=true
